# AgriMind Agent Environment Variables

# Option 1: Gemini Developer API key for local development.
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Google Cloud / Vertex AI for Cloud Run service-account auth.
# Set GOOGLE_GENAI_USE_VERTEXAI=true in Cloud Run when you do not want to store an API key.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

PORT=8080
